{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/secrets-scanner/scan-secrets.sh",
        "powershell": "pwsh -NoProfile -File .github/hooks/secrets-scanner/scan-secrets.ps1",
        "cwd": ".",
        "env": {
          "SCAN_MODE": "block",
          "SCAN_SCOPE": "diff",
          "SECRETS_ALLOWLIST": "BEGIN PGP PRIVATE KEY BLOCK,BEGIN RSA PRIVATE KEY,service_account,user:pass@host,192.168.1.1:8080,wJalr"
        },
        "timeoutSec": 30
      }
    ]
  }
}
