@page "/"
@namespace MjrChess.Trainer.Pages
@using Microsoft.Extensions.DependencyInjection
@inject IServiceProvider Services
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    // JavaScriptSnippet is only registered when Application Insights telemetry has
    // been added in Startup.ConfigureServices (which only happens when an AI
    // connection string / instrumentation key is configured). Use GetService so
    // the page degrades gracefully when telemetry is off.
    var javaScriptSnippet = Services.GetService<Microsoft.ApplicationInsights.AspNetCore.JavaScriptSnippet>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chess Trainer</title>
    <link href="app.bundle.css" rel="stylesheet" />
    @if (javaScriptSnippet is not null)
    {
        @Html.Raw(javaScriptSnippet.FullScript)
    }
    <base href="~/" />
</head>
<body>
    <app>
        <component type="typeof(App)" render-mode="ServerPrerendered" />
    </app>

    <!-- Toast notification divs -->
    <div id="PrimaryNotifier" class="mdc-snackbar mdc-snackbar--stacked">
        <div class="mdc-snackbar__surface">
            <div id="PrimaryNotifierLabel" class="mdc-snackbar__label"
                 role="status"
                 aria-live="polite">
            </div>
            <div class="mdc-snackbar__actions">
                <button type="button" class="mdc-button mdc-snackbar__dismiss">
                    Ok
                </button>
            </div>
        </div>
    </div>
    <div id="CopyNotifier" class="mdc-snackbar mdc-snackbar--stacked">
        <div class="mdc-snackbar__surface">
            <div id="CopyNotifierLabel" class="mdc-snackbar__label"
                 role="status"
                 aria-live="polite">
            </div>
            <div class="mdc-snackbar__actions">
                <button id="CopyButton" type="button" class="mdc-button mdc-snackbar__action">
                    Copy
                </button>
                <button type="button" class="mdc-button mdc-snackbar__dismiss">
                    Ok
                </button>
            </div>
        </div>
    </div>
    <script src="_framework/blazor.server.js"></script>
    <script src="app.bundle.js"></script>
</body>
</html>
